<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.betanalyzier.ui.home.HomeFragment"
        android:title="Inicio"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_leagues"
        android:name="com.example.betanalyzier.ui.leagues.LeaguesFragment"
        android:title="Ligas"
        tools:layout="@layout/fragment_leagues" />

    <fragment
        android:id="@+id/nav_live"
        android:name="com.example.betanalyzier.ui.live.LiveFragment"
        android:title="En Directo"
        tools:layout="@layout/fragment_live" />

    <activity
        android:id="@+id/matchDetailActivity"
        android:name="com.example.betanalyzier.ui.detail.MatchDetailActivity"
        android:title="Detalle del Partido"
        tools:layout="@layout/activity_match_detail">
        <argument
            android:name="fixtureId"
            app:argType="integer" />
    </activity>

</navigation>