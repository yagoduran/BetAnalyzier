<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BetAnalyzier" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/bet_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/bet_red</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/bet_red</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/deep_grey</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Background colors. -->
        <item name="android:windowBackground">@color/deep_grey</item>
        <item name="colorSurface">@color/surface_grey</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/surface_grey</item>
        <item name="colorOnSurfaceVariant">@color/white</item>
    </style>

    <style name="Theme.BetAnalyzier" parent="Base.Theme.BetAnalyzier" />
</resources>